{
    "layer": "top",
    "height": 30,

    "include": [
      "~/.config/hypr/waybar/modules.base.json"
    ],

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": [
      "group/system",
      "group/keyboard",
      "group/hardware",
      "clock",
      "custom/wlogout"
    ],

    "group/system": {
        "orientation": "horizontal",
        "modules": [
            "backlight",
            "pulseaudio",
            "network"
        ]
    },

    "group/keyboard": {
        "orientation": "horizontal",
        "modules": [
            "hyprland/language",
            "keyboard-state"
        ]
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "disk",
            "cpu",
            "memory"
        ]
    }
}
